<?xml version="1.0" encoding="utf-8"?>
<!--
    backup_rules.xml

    Controls what gets backed up via Android Auto Backup (API < 31).
    We exclude encrypted preferences (they contain auth tokens that won't
    work on a different device) and the JRE installation (large, re-downloadable).
-->
<full-backup-content>
    <!-- Include settings -->
    <include domain="file" path="datastore/" />
    <!-- Exclude sensitive / large data -->
    <exclude domain="sharedpref" path="novacraft_secure_prefs.xml" />
    <exclude domain="file" path="jre/" />
    <exclude domain="file" path="natives/" />
</full-backup-content>
